# PostgreSQL
# When running via Docker: use host.docker.internal to reach PostgreSQL on the host machine
# When running directly on the server: use localhost
PG_HOST=host.docker.internal
PG_PORT=5432
PG_DB=options
PG_USER=your_db_user
PG_PASSWORD=your_db_password

# Polygon.io (for historical data scripts)
POLYGON_API_KEY=your_polygon_api_key
